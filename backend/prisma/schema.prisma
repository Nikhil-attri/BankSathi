generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  AGENT
  ADMIN
}

enum LeadStage {
  NEW
  VERIFIED
  APPLIED
  APPROVED
  DISBURSED
  REJECTED
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ComplaintCategory {
  LOAN
  KYC
  PAYMENT
  FRAUD
  TECHNICAL
  OTHER
}

model User {
  id             String      @id @default(cuid())
  fullName       String
  phone          String      @unique
  email          String?     @unique
  role           Role        @default(AGENT)
  kycVerified    Boolean     @default(false)
  preferredLang  String      @default("en")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  leads          Lead[]      @relation("AgentLeads")
  complaints     Complaint[] @relation("UserComplaints")
}

model Product {
  id             String   @id @default(cuid())
  name           String
  type           String
  provider       String
  minInterest    Float?
  maxInterest    Float?
  metadata       Json?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  leads          Lead[]
}

model Lead {
  id                 String     @id @default(cuid())
  customerName       String
  customerPhone      String
  customerIncome     Float?
  creditScore        Int?
  monthlyObligations Float?
  stage              LeadStage  @default(NEW)
  mlScore            Float?
  assignedAgentId    String
  productId          String?
  notes              String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  assignedAgent      User       @relation("AgentLeads", fields: [assignedAgentId], references: [id])
  product            Product?   @relation(fields: [productId], references: [id])
  complaints         Complaint[]
}

model Complaint {
  id                String            @id @default(cuid())
  ticketId          String            @unique
  title             String
  description       String
  category          ComplaintCategory @default(OTHER)
  priority          ComplaintPriority @default(MEDIUM)
  status            ComplaintStatus   @default(OPEN)
  language          String            @default("en")
  sentimentScore    Float?
  assignedTeam      String?
  slaDeadline       DateTime?
  userId            String
  leadId            String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation("UserComplaints", fields: [userId], references: [id])
  lead              Lead?             @relation(fields: [leadId], references: [id])
}
